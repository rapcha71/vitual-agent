# Copiá este archivo como .env y completá con tus valores de Replit
# Para pruebas en celular con cámara y GPS: USE_HTTPS_DEV=true (luego npm run dev:https)
# En Replit: Secrets (candado) → copiá cada variable

DATABASE_URL=postgresql://usuario:password@host/database?sslmode=require
SESSION_SECRET=tu-clave-secreta-aleatoria-muy-larga

# Para el mapa (necesario para ver propiedades en el mapa)
# VITE_GOOGLE_MAPS_API_KEY=tu-api-key-de-google-maps
# En Google Cloud Console → API key → Restricciones → agregá:
#   - Local: http://localhost:5000/* y http://192.168.*.*/*
#   - Producción: https://tu-app.railway.app/*

# Envío de correos (códigos de recuperación de contraseña)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-app-password
# SMTP_FROM=Virtual Agent <noreply@tudominio.com>

# Opcionales (si usás Google Sheets y OCR)
# GOOGLE_SHEETS_CREDENTIALS={"type":"service_account",...}
# GOOGLE_SHEETS_ID=tu-spreadsheet-id
# APP_URL=http://localhost:5000
